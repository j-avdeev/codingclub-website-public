---
const navItems = [
  {
    href: "#events",
    label: "Events",
  },
  {
    href: "#connect",
    label: "Connect",
  },
  {
    href: "#partner",
    label: "Partner",
  },
  {
    href: "#contact",
    label: "Contact",
  },
];
---

<header class="fixed left-0 top-0 z-50 w-full border-b border-slate-200/80 bg-white/95 shadow-sm backdrop-blur">
  <div class="mx-auto flex w-full max-w-[1100px] items-center gap-3 px-4 py-2 md:px-6">
    <a class="shrink-0 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" href="/" aria-label="Coding Club home">
      <img class="block h-auto w-14 rounded-full md:w-16" src="/logo.jpeg" alt="Coding Club logo" />
    </a>
    <nav class="min-w-0 flex-1" aria-label="Main navigation">
      <ul class="ml-auto flex w-fit max-w-full items-center justify-end gap-1 overflow-x-auto md:gap-3">
      {
        navItems.map((item) => (
          <li class="list-none font-mono text-[13px] font-medium md:text-[1.1rem]">
            <a class="inline-block rounded-full px-3 py-2 text-slate-700 no-underline transition hover:bg-slate-100 hover:text-slate-950 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 md:px-4" href={item.href}>
              {item.label}
            </a>
          </li>
        ))
      }
      </ul>
    </nav>
  </div>
</header>
