---
interface Props {
  title: string;
  tagline: string;
  schedule: string;
}

const { title, tagline, schedule } = Astro.props;
---

<section id="events" class="flex w-full flex-col items-center justify-center px-4">
  <h1 class="mb-3 mt-14 text-center text-[clamp(2rem,5vw,2.85rem)] font-extrabold tracking-normal text-slate-950 md:mt-16">
    {title}
  </h1>
  <p class="mb-1 max-w-[620px] text-center font-sans text-base text-slate-700 md:text-lg">{tagline}</p>
  <p class="mb-3 max-w-[620px] text-center font-sans text-base font-semibold text-slate-900 md:text-lg">{schedule}</p>
  <iframe
    class="mt-3 h-[320px] max-h-[calc(100vh-260px)] w-full max-w-[520px] rounded-2xl border border-slate-200 shadow-lg shadow-slate-200/70 md:h-[420px]"
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2659.552213029674!2d16.335251576621094!3d48.19597857124996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x476d07c0496e3d1b%3A0x14285a13471b6306!2sJO%26JOE%20Wien!5e0!3m2!1sen!2sat!4v1709737886565!5m2!1sen!2sat"
    width="600"
    height="450"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="Jo&Joe Vienna map"
  ></iframe>
</section>
