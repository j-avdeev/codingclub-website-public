---
import SectionTitle from "./SectionTitle.astro";

interface ProjectLink {
  href: string;
  icon: string;
  label: string;
}

interface Project {
  title: string;
  author: string;
  image: string;
  imageAlt: string;
  wide?: boolean;
  links: ProjectLink[];
}

interface Props {
  title: string;
  projects: Project[];
}

const { title, projects } = Astro.props;
---

<section>
  <SectionTitle>{title}</SectionTitle>
  <div class="mx-auto flex max-w-[900px] flex-wrap items-center justify-center">
    {
      projects.map((project) => (
        <figure class="text-center">
          <img
            class:list={[
              "mx-2.5 mt-5 rounded-[15px]",
              project.wide ? "h-[150px] w-[350px]" : "h-[180px] w-[180px]",
            ]}
            src={project.image}
            alt={project.imageAlt}
            loading="lazy"
          />
          <figcaption>
            <h3 class="text-center text-[30px] font-bold">{project.title}</h3>
            <p class="text-center text-[15px]">by {project.author}</p>
          </figcaption>
          <div class="flex justify-center">
            {
              project.links.map((link) => (
                <a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
                  <img
                    class="mx-2.5 mt-5 h-10 w-10 rounded-[15px]"
                    src={link.icon}
                    alt=""
                    loading="lazy"
                  />
                </a>
              ))
            }
          </div>
        </figure>
      ))
    }
  </div>
</section>
