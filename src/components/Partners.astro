---
interface Partner {
  href: string;
  image: string;
  alt: string;
  className: string;
}

interface Props {
  title: string;
  partners: Partner[];
}

const { title, partners } = Astro.props;
---

<section id="partner" class="w-full px-4">
  <h1 class="mb-6 mt-20 text-center text-[clamp(2rem,6vw,3.25rem)] font-extrabold tracking-normal text-slate-950 md:mt-24">{title}</h1>
  <div class="mx-auto flex max-w-[820px] flex-row flex-wrap items-center justify-center gap-3">
    {
      partners.map((partner) => (
        <a class="flex h-28 min-w-32 items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" href={partner.href} target="_blank" rel="noreferrer">
          <img
            class={`${partner.className} max-h-20 object-contain max-md:h-auto max-md:w-20`}
            src={partner.image}
            alt={partner.alt}
            loading="lazy"
          />
        </a>
      ))
    }
  </div>
</section>
